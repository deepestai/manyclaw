{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["bots"],
  "properties": {
    "bots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "discordId", "mention", "owner", "active"],
        "properties": {
          "name":     { "type": "string" },
          "discordId": { "type": "string", "pattern": "^[0-9]{16,20}$" },
          "mention":  { "type": "string", "pattern": "^<@[0-9]+>$" },
          "owner":    { "type": ["string", "null"] },
          "active":   { "type": "boolean" },
          "aliases":  { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "humans": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "discordId", "mention", "role"],
        "properties": {
          "name":     { "type": "string" },
          "discordId": { "type": "string", "pattern": "^[0-9]{16,20}$" },
          "mention":  { "type": "string", "pattern": "^<@[0-9]+>$" },
          "role":     { "type": "string" }
        }
      }
    }
  }
}
